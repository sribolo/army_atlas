# Copy this file to .env and fill in real values. Never commit .env.

# development | testing | production
FLASK_CONFIG=development

# 5001, not Flask's default 5000 — macOS's AirPlay Receiver binds 5000 and
# will intercept requests instead. `flask run` reads this automatically.
FLASK_RUN_PORT=5001

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-secret-key

# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/army_atlas

# Optional: Redis URL for Flask-Limiter storage in production.
# Defaults to in-memory storage, which is fine for local development only.
RATELIMIT_STORAGE_URI=memory://

# Mail (password reset links). Ignored in development/testing, where the
# reset link is logged to the console instead of sent.
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=replace-with-smtp-username
MAIL_PASSWORD=replace-with-smtp-password
MAIL_DEFAULT_SENDER=no-reply@armyatlas.local

# Cloudinary (profile picture storage)
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
